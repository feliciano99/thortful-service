# Copy to .env and adjust. Compose falls back to these same defaults if .env is absent,
# so `docker compose up --build` works out of the box; .env overrides for real secrets.

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_DB=thortful
POSTGRES_USER=thortful
POSTGRES_PASSWORD=thortful

# ── Backend datasource (points at the compose postgres service) ─
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/thortful

# ── HTTP Basic Auth credentials (backend + frontend) ───────────
APP_AUTH_USER=admin
APP_AUTH_PASSWORD=changeme
