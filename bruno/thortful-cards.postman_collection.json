{
  "info": {
    "name": "Thortful Cards",
    "description": "Greeting Cards REST API. Base path /cards/v1. Cards endpoints require HTTP Basic auth (admin / changeme); categories, health and swagger are public.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      { "key": "username", "value": "{{username}}", "type": "string" },
      { "key": "password", "value": "{{password}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "username", "value": "admin" },
    { "key": "password", "value": "changeme" }
  ],
  "item": [
    {
      "name": "Cards",
      "item": [
        {
          "name": "List cards",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{username}}", "type": "string" },
                { "key": "password", "value": "{{password}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cards/v1/cards?page=0&size=20&sort=title,asc",
              "host": ["{{baseUrl}}"],
              "path": ["cards", "v1", "cards"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "sort", "value": "title,asc" },
                { "key": "search", "value": "Birthday", "disabled": true },
                { "key": "category", "value": "BIRTHDAY", "disabled": true }
              ]
            },
            "description": "Paginated/sortable list. sort=field,dir (title|price|category|artist). Optional search (title contains) and category (enum) filters. Returns PagedModel { content, page }."
          }
        },
        {
          "name": "Search by title",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{username}}", "type": "string" },
                { "key": "password", "value": "{{password}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cards/v1/cards?search=Eagle&page=0&size=20&sort=title,asc",
              "host": ["{{baseUrl}}"],
              "path": ["cards", "v1", "cards"],
              "query": [
                { "key": "search", "value": "Eagle" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "sort", "value": "title,asc" }
              ]
            }
          }
        },
        {
          "name": "Filter by category",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{username}}", "type": "string" },
                { "key": "password", "value": "{{password}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cards/v1/cards?category=BIRTHDAY&page=0&size=20&sort=price,desc",
              "host": ["{{baseUrl}}"],
              "path": ["cards", "v1", "cards"],
              "query": [
                { "key": "category", "value": "BIRTHDAY" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "sort", "value": "price,desc" }
              ]
            }
          }
        },
        {
          "name": "Create card",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{username}}", "type": "string" },
                { "key": "password", "value": "{{password}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Sunny Birthday Wishes\",\n  \"category\": \"BIRTHDAY\",\n  \"artist\": \"Jane Doe\",\n  \"price\": 4.50,\n  \"stockStatus\": \"IN_STOCK\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/cards/v1/cards",
              "host": ["{{baseUrl}}"],
              "path": ["cards", "v1", "cards"]
            },
            "description": "201 + Location on success. category: BIRTHDAY|ANNIVERSARY|THANK_YOU|CONGRATULATIONS|GET_WELL|WEDDING|NEW_BABY|CHRISTMAS|VALENTINES_DAY|SYMPATHY. stockStatus: IN_STOCK|LOW_STOCK|OUT_OF_STOCK."
          }
        },
        {
          "name": "Create card (invalid - 400)",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{username}}", "type": "string" },
                { "key": "password", "value": "{{password}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"\",\n  \"category\": \"BIRTHDAY\",\n  \"artist\": \"Jane Doe\",\n  \"price\": -1,\n  \"stockStatus\": null\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/cards/v1/cards",
              "host": ["{{baseUrl}}"],
              "path": ["cards", "v1", "cards"]
            },
            "description": "Returns 400 ApiError with fieldErrors for title, price and stockStatus."
          }
        },
        {
          "name": "Delete card",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{username}}", "type": "string" },
                { "key": "password", "value": "{{password}}", "type": "string" }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cards/v1/cards/:id",
              "host": ["{{baseUrl}}"],
              "path": ["cards", "v1", "cards", ":id"],
              "variable": [{ "key": "id", "value": "1" }]
            },
            "description": "204 on success, 404 (ApiError) if not found. Set :id to a real id from List cards."
          }
        },
        {
          "name": "List cards (unauthorized - 401)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cards/v1/cards?size=1",
              "host": ["{{baseUrl}}"],
              "path": ["cards", "v1", "cards"],
              "query": [{ "key": "size", "value": "1" }]
            },
            "description": "No Authorization header -> clean JSON 401 (no WWW-Authenticate, so no browser popup)."
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List categories",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cards/v1/categories",
              "host": ["{{baseUrl}}"],
              "path": ["cards", "v1", "categories"]
            },
            "description": "Public. Category enum values + display labels."
          }
        }
      ]
    },
    {
      "name": "System",
      "item": [
        {
          "name": "Health",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cards/v1/actuator/health",
              "host": ["{{baseUrl}}"],
              "path": ["cards", "v1", "actuator", "health"]
            },
            "description": "Public actuator health (polled by the container healthcheck)."
          }
        }
      ]
    }
  ]
}
